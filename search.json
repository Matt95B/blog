---
layout: null
---
[
  {% for post in site.posts %}
    {
      "title"    : {{ post.title | jsonify }},
      "article"  : "<div class=\"article col col-12 animate\"><div class=\"article__inner\"><div class=\"article__content\"><h2 class=\"article__title\"><a href=\"{{ post.url | prepend: site.baseurl }}\">{{ post.title | escape }}</a></h2><p class=\"article__excerpt\">{{ post.description | escape }}</p>{% if post.tags.size >= 1 %}<div class=\"article__bottom\"><div class=\"article-tags__box\">{% for tag in post.tags %}<a href=\"{{ site.baseurl }}/posts?tag={{ tag }}\" class=\"article__tag\">{{ tag }}</a>{% endfor %}</div></div>{% endif %}</div></div></div>",
      "category" : {{ post.category | jsonify }},
      "tags"     : {{ post.tags | array_to_sentence_string | jsonify }},
      "url"      : {{ post.url | prepend: site.baseurl | jsonify }},
      "date"     : {{ post.date | jsonify }},
      "content"  : {{ post.content | strip_html | strip_newlines | jsonify }}
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
